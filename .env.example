# Backend API
NEXT_PUBLIC_API_URL=

# Frontend domain (sin protocolo, ej: turno1min.app)
NEXT_PUBLIC_FRONT_SHORT=

# Admin tenant ID
NEXT_PUBLIC_ADMIN_TENANT_ID=

# Meta Pixel ID (Facebook Ads). Si está vacío, el pixel se desactiva en runtime.
NEXT_PUBLIC_META_PIXEL_ID=

# VAPID public key para notificaciones push (debe matchear VAPID_PUBLIC_KEY del backend).
# OJO: Next la inlinea en BUILD time — si falta al compilar, NADIE puede
# suscribirse a push. Verificá que esté seteada en el host antes de buildear.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Cloudinary — subida de la foto de perfil del negocio (unsigned upload).
# CLOUD_NAME: lo ves en el Dashboard de Cloudinary.
# UPLOAD_PRESET: Settings → Upload → Upload presets → Add (Signing Mode: Unsigned).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
